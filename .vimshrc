# ファイルとディレクトリを区別して表示
alias ls='ls -Fh'
alias l='ls -Fh'
# cdコマンドの省略
alias ..='cd ..'
alias ...='cd ../../'
alias ....='cd ../../../'
alias .....='cd ../../../../'
alias ......='cd ../../../../../'
# source
alias s='source'
# remove (recursive)
alias die="sudo rm -r"
# vim
alias v='vim'
# exit
alias e='exit'
# rails
alias r='rails'
# project directory
alias @='cd ~/Documents/code/'
# git add .
alias ga.='git add .'
# git commit
alias gc='git commit -m'
# git push origin master
alias gpom='git push origin master'
